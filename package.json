{
  "name": "tort-app-backend",
  "version": "1.0.0",
  "description": "Backend pentru platformă vânzare torturi",
  "main": "index.js",
  "scripts": {
    "quality": "npm run quality:backend && npm run quality:frontend",
    "quality:backend": "npm --prefix backend run quality",
    "quality:frontend": "npm --prefix frontend run quality",
    "quality:standards": "node tools/quality/check-code-standards.mjs",
    "test:backend:integration": "npm --prefix backend run test:integration",
    "test:frontend:e2e:ci": "npm --prefix frontend run cypress:run:ci",
    "test:frontend:e2e:live": "npm --prefix frontend run cypress:run:live",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "npm run quality",
    "checklist": "node scripts/checklist.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
