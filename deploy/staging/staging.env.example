# Acest fisier este un exemplu pentru secretul GitHub `STAGING_ENV_FILE`.
# Workflow-ul completeaza automat `BACKEND_IMAGE` si `FRONTEND_IMAGE`.

APP_STACK=maison-douce-staging

# Porturi expuse doar local pe server. Pune reverse proxy in fata pentru acces public.
FRONTEND_PORT=8080
BACKEND_PORT=5000
MONGO_PORT=27017

BASE_CLIENT_URL=https://staging.example.com
BODY_LIMIT=10mb
TRUST_PROXY=1

MONGODB_URI=mongodb://mongo:27017/torturi
JWT_SECRET=change_me_before_staging
JWT_EXPIRES=7d
MIN_LEAD_HOURS=24
RESET_TOKEN_TTL_MIN=60
PATISER_INVITE_CODE=PATISER-INVITE

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=mdl

SMTP_HOST=
SMTP_SERVICE=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Maison-Douce <no-reply@staging.example.com>

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@staging.example.com

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_SIZE=1024x1024
