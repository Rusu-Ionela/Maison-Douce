# Acest fisier este un exemplu pentru secretul GitHub `PRODUCTION_ENV_FILE`.
# Workflow-ul completeaza automat `BACKEND_IMAGE` si `FRONTEND_IMAGE`.

APP_STACK=maison-douce-prod

# Porturi expuse doar local pe server. Pune reverse proxy in fata pentru acces public.
FRONTEND_PORT=8080
BACKEND_PORT=5000
MONGO_PORT=27017

BASE_CLIENT_URL=https://example.com
BODY_LIMIT=10mb
TRUST_PROXY=1

MONGODB_URI=mongodb://mongo:27017/torturi
JWT_SECRET=replace_with_a_strong_32_plus_char_secret
JWT_EXPIRES=7d
MIN_LEAD_HOURS=24
RESET_TOKEN_TTL_MIN=60
PATISER_INVITE_CODE=replace_with_a_strong_private_invite_code

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=mdl

SMTP_HOST=
SMTP_SERVICE=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Maison-Douce <no-reply@example.com>

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_SIZE=1024x1024

# Config frontend injectat la runtime in containerul nginx.
VITE_API_URL=/api
VITE_PRESTATOR_ID=replace_with_real_prestator_id
VITE_STRIPE_PK=
VITE_MIN_LEAD_HOURS=24
