# Example environment variables for frontend
# Copy this to `frontend/.env.local` for local development.

VITE_API_URL=http://localhost:5000/api

# Required for calendar flows. Leave `default` only for local fallback/testing.
VITE_PRESTATOR_ID=default

# Optional if you want embedded Stripe Payment Element in the UI.
VITE_STRIPE_PK=pk_test_xxx

# Optional lead time used by calendar and checkout flows.
VITE_MIN_LEAD_HOURS=24

# Optional app release label used in client error reporting.
VITE_APP_VERSION=local
